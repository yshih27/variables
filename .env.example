# ─────────────────────────────────────────────────────────────────────────────
# Environment template — copy to .env.local and fill in real values.
#   cp .env.example .env.local
# This file lists NAMES ONLY (no secrets). The scheduled data pipeline needs the
# same keys as GitHub Actions secrets — see .github/workflows/warm.yml.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase — Postgres data store (snapshots + metric_snapshots + cards table) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=            # server-only; full DB access (warmers + reads)
NEXT_PUBLIC_SUPABASE_URL=             # client-exposed
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= # client-exposed anon / publishable key

# ── Data-source API keys (warmers) ──
HELIUS_API_KEY=   # Solana DAS — Collector Crypt + Phygitals holders & traits
DUNE_API_KEY=     # Dune Analytics — secondary sales + gacha daily volume
RARIBLE_API_KEY=  # Rarible — Beezie ownerships / metadata
FRED_API_KEY=     # St. Louis Fed — S&P 500 + NASDAQ benchmark closes (free key)
                  # (BTC/ETH/GOLD benchmarks use CoinGecko — no key needed.)

# ── App / cron ──
CRON_SECRET=      # bearer token guarding the /api/cron/* routes

# ── Public API v1 (/api/v1/*) — attribution-required free tier ──
API_V1_KEYS=        # comma-separated label:secret pairs, e.g. "acme:vk_x7…,press:vk_a4…"
API_V1_DAILY_QUOTA= # requests per key per UTC day (default 1000)
